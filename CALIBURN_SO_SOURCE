local function gradientanimation(grad)
	local ti = TweenInfo.new(3, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1)
	TweenService:Create(grad, ti, {Rotation = grad.Rotation + 360}):Play()
end

local function makeGradient(parent, c1, c2, name, animate)
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(c1[1],c1[2],c1[3])),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(c2[1],c2[2],c2[3]))
	}
	g.Rotation = -89
	g.Parent = parent
	if name then g.Name = name end
	if animate then gradientanimation(g) end
	return g
end

