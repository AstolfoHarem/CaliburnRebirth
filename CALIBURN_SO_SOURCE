local function faceDownAtMob()
	if _G.AutoFarmSettings.Autofarm == false then return end
	local char, hrp, hum = getChar()
	if not char then return end
	hum.AutoRotate = false
	hum.PlatformStand = true
	local bv = hrp:FindFirstChild("HoverBV")
	if not bv then
		bv = Instance.new("BodyVelocity")
		bv.Name = "HoverBV"
		bv.MaxForce = Vector3.new(8999999488, 8999999488, 8999999488)
		bv.Velocity = Vector3.zero
		bv.P = 1250
		bv.Parent = hrp
	end
end

function _G.safeTP(cf)
	getgenv().antiTP_bypass = true
	local hrp = getHRP()
	if hrp then
		hrp.CFrame = cf * CFrame.Angles(math.rad(-90), 0, 0)
		faceDownAtMob()
	end
	task.wait()
	getgenv().antiTP_bypass = false
end

local Level = 1

local function getLevel()
	local pg = Player:FindFirstChild("PlayerGui") if not pg then return Level end
	local core = pg:FindFirstChild("CoreGUI") if not core then return Level end
	local frame = core:FindFirstChild("Frame") if not frame then return Level end
	local expbar = frame:FindFirstChild("EXPBAR") if not expbar then return Level end
	local status = expbar:FindFirstChild("Status") if not status then return Level end
	local lvl = status:FindFirstChild("Level") if not lvl then return Level end
	if typeof(lvl.Value) == "number" then Level = lvl.Value end
	return Level
end

local function getQuestData(level)
	if level <= 9 then return "Thug Quest","Thug","ThugQuest"
	elseif level <= 19 then return "Brute Quest","Brute","BruteQuest"
	elseif level <= 29 then return "🦍😡💢 Quest","🦍","GorillaQuest"
	elseif level <= 44 then return "Werewolf Quest","Werewolf","WerewolfQuest"
	elseif level <= 59 then return "Zombie Quest","Zombie","ZombieQuest"
	elseif level <= 79 then return "Vampire Quest","Vampire","VampireQuest"
	else return "Golem Quest","HamonGolem","GolemQuest"
	end
end

local function InvokeIfStandOutFalse()
	if not _G.AutoFarmSettings.UseStand then return end
	local character = Player and Player.Character
	local status = character and character:FindFirstChild("Status")
	local standOut = status and status:FindFirstChild("StandOut")
	if standOut and standOut:IsA("BoolValue") and standOut.Value == false then
		local gui = Player:FindFirstChild("PlayerGui")
		local core = gui and gui:FindFirstChild("CoreGUI")
		local events = core and core:FindFirstChild("Events")
		local summon = events and events:FindFirstChild("SummonStand")
		if summon then pcall(function() summon:InvokeServer() end) end
	end
end

local function getFire(moveName)
	local ok, result = pcall(function()
		local pg = Player:FindFirstChild("PlayerGui") if not pg then return nil end
		local core = pg:FindFirstChild("CoreGUI") if not core then return nil end
		local standMoves = core:FindFirstChild("StandMoves") if not standMoves then return nil end
		local move = standMoves:FindFirstChild(moveName) if not move then return nil end
		return move:FindFirstChild("Fire")
	end)
	if ok then return result end
end

