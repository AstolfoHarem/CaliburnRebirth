-- ===================== MAIN LOOP =====================

local _loopThread

_G.AutoFarmCleanup = function()
	_G.AutoFarmSettings.Autofarm = false
	if _loopThread then pcall(task.cancel, _loopThread) end
	for _, c in pairs(_connections) do
		pcall(function() c:Disconnect() end)
	end
	table.clear(_connections)
	stop()
	clip()
	local existing = game:GetService("CoreGui"):FindFirstChild("AutoFarmGUI")
	if existing then existing:Destroy() end
end

_loopThread = task.spawn(function()
  pcall(function()
	if _G.AutoFarmSettings.Autofarm then noclip() end
		while true do
			if _G.AutoFarmSettings.Autofarm then
				if _G.AutoFarmSettings.AutoPrestige and Level >= 100 then
					Prestiging = true
					task.defer(function()
						for i = 1, 10 do
							faceDownAtMob()
							task.wait(0.1)
						end
					end)
					Prestige()
					Level = getLevel()
					task.wait(3)
					Prestiging = false
				end
				Level = getLevel()
				task.wait()
				local questGiverName, mobName, questName = getQuestData(Level)
				if not hasQuest(questName) then
					repeat
						local questGiver = findNPC(questGiverName)
						if questGiver and questGiver:FindFirstChild("HumanoidRootPart") then
							_G.safeTP(questGiver.HumanoidRootPart.CFrame + Vector3.new(0,3,0))
							task.wait(0.3)
							local prompt = questGiver:FindFirstChildWhichIsA("ProximityPrompt")
							if prompt then fireproximityprompt(prompt) end
						end
						task.wait(0.5)
					until hasQuest(questName)
					task.wait()
				end
				InvokeIfStandOutFalse()
				attackMob(mobName)
			end
			task.wait()
		end
	end)
end)
