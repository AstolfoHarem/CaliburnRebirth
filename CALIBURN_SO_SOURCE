local function AllocateStat(statName)
	local gui = Player:FindFirstChild("PlayerGui") if not gui then return end
	local core = gui:FindFirstChild("CoreGUI") if not core then return end
	local statsUI = core:FindFirstChild("Stats") if not statsUI then return end
	local statsUI2 = statsUI:FindFirstChild("Stats") if not statsUI2 then return end
	local remote = statsUI2:FindFirstChild("Stats") if not remote then return end
	local skillpoints = statsUI2:FindFirstChild("aSkillPoints") if not skillpoints then return end
	local number = tonumber(skillpoints.Text and skillpoints.Text:match("%d+")) or 1
	if remote:IsA("RemoteFunction") then return remote:InvokeServer(statName, number) end
end

