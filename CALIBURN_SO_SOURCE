local function hasQuest(QuestName)
	local pg = Player:FindFirstChild("PlayerGui") if not pg then return false end
	for _, v in ipairs(pg:GetChildren()) do
		if v.Name == "Quest" then
			local qf = v:FindFirstChild("Quest")
			if qf and qf:FindFirstChild(QuestName) then return true end
		end
	end
	return false
