local function getChar()
	local char = Player.Character
	if not char then return nil end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return nil end
	return char, hrp, hum
end

local function getHRP()
	local char = Player.Character
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart")
end

local function stop()
	if hbConn then hbConn:Disconnect() end
	if changedConn then changedConn:Disconnect() end
	if diedConn then diedConn:Disconnect() end
end

local function start()
	local hrp
	repeat local _, h = getChar() hrp = h task.wait() until hrp
	stop()
	lastCF = hrp.CFrame
	hbConn = trackConn(RunService.Heartbeat:Connect(function()
		if reverting then return end
		local h = getHRP()
		if h then lastCF = h.CFrame end
	end))
	changedConn = trackConn(hrp:GetPropertyChangedSignal('CFrame'):Connect(function()
		if reverting then return end
		if getgenv().antiTP_bypass then lastCF = hrp.CFrame return end
		local delta = (hrp.Position - lastCF.Position).Magnitude
		if delta < getgenv().antiTP_threshold then lastCF = hrp.CFrame return end
		reverting = true
		hrp.CFrame = lastCF
		RunService.Heartbeat:Wait()
		reverting = false
	end))
	diedConn = trackConn(Player.Character:FindFirstChildOfClass('Humanoid').Died:Connect(stop))
end

