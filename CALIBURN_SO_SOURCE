local function findNPC(name)
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and obj.Name == name then return obj end
	end
end

local function getMob(name)
	for _, mob in ipairs(workspace:GetChildren()) do
		if mob.Name == name then
			local hum = mob:FindFirstChild("Humanoid")
			local hrp = mob:FindFirstChild("HumanoidRootPart")
			if mob:IsA("Model") and hum and hrp and hum.Health > 0 then return mob, hum, hrp end
		end
	end
end

local function isDead(mob)
	local hum = mob and mob:FindFirstChildOfClass("Humanoid")
	return (not hum) or hum.Health <= 0
end

local function attackMob(name)
	local startTime = tick()
	local mob, hum, hrp = getMob(name)
	if not hum or not hrp then return end
	while mob and not isDead(mob) and not Prestiging do
		RunService.Heartbeat:Wait()
		if tick() - startTime > 10 then break end
		local char, plrhrp = getChar()
		if not plrhrp or Prestiging then return end
		task.defer(function() pcall(function() AllocateStat("Strength") end) end)
		if not mob or hum.Health <= 0 then break end
		_G.safeTP(hrp.CFrame + hrp.CFrame.UpVector * _G.AutoFarmSettings.Height)
		task.defer(function()
			if _G.AutoFarmSettings.Attacks.Heavy then pcall(Heavy) end
			if _G.AutoFarmSettings.Attacks.Barrage then pcall(Barrage) end
			if _G.AutoFarmSettings.Attacks.Chop then pcall(Chop) end
			pcall(Punch)
		end)
	end
end

local function SetupBaseplate()
	-- Create baseplate first (if not already made)
  if not workspace:FindFirstChild("BaseplateFolder") then
      local folder = Instance.new("Folder")
      folder.Name = "BaseplateFolder"
      folder.Parent = workspace
  
      local size = Vector3.new(2048, 1, 2048)
      local spacing = 2048 -- match size so they touch
      local centerPos = Vector3.new(0, 270, 0)
  
      local function createPlate(pos)
          local p = Instance.new("Part")
          p.Name = "Baseplate"
          p.Size = size
          p.Position = pos
          p.Anchored = true
          p.TopSurface = Enum.SurfaceType.Smooth
          p.BottomSurface = Enum.SurfaceType.Smooth
          p.Material = Enum.Material.Grass
          p.Parent = folder
      end
  
      -- center plate
      createPlate(centerPos)
  
      -- surrounding 8 plates
      for x = -1, 1 do
          for z = -1, 1 do
              if not (x == 0 and z == 0) then
                  local offset = Vector3.new(x * spacing, 0, z * spacing)
                  createPlate(centerPos + offset)
              end
          end
      end
  end
	task.wait()
	
	if workspace:FindFirstChild("DAMAGE BARRIER") then
	  workspace["DAMAGE BARRIER"]:Destroy()
	  for i,v in pairs(workspace:GetChildren()) do
	    if v.Name == "Blightmore" then v:Destroy() end
    end
  end

	
	-- Then delete map if it exists
	local map = workspace:FindFirstChild("Map")
	if map then
		map:Destroy()
	end
end

function noclip()
	if Clip == false then return end
	Clip = false
	Noclip = trackConn(RunService.Stepped:Connect(function()
		if Clip == false and Player.Character then
			for _,v in pairs(Player.Character:GetDescendants()) do
				if v:IsA('BasePart') and v.CanCollide and v.Name ~= "Float" then
					v.CanCollide = false
				end
			end
		end
		task.wait(0.2)
	end))
end

function clip()
	if Noclip then Noclip:Disconnect() end
	Clip = true
end

