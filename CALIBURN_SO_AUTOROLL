	fill.Parent = track
	fill.BackgroundColor3 = Color3.fromRGB(255,60,255)
	fill.BorderSizePixel = 0
	fill.Size = UDim2.new((currentVal - minVal)/(maxVal - minVal), 0, 1, 0)
	makeGradient(fill, {255,60,255}, {255,175,255}, nil, true)

	local knob = Instance.new("TextButton")
	knob.Parent = track
	knob.BackgroundColor3 = Color3.fromRGB(220,220,220)
	knob.BorderSizePixel = 0
	knob.Text = ""
	knob.Size = UDim2.new(0,10,0,12)
	knob.Position = UDim2.new((currentVal - minVal)/(maxVal - minVal), -5, 0, -3)
	knob.AutoButtonColor = false

	local dragging = false
	knob.MouseButton1Down:Connect(function() dragging = true end)
	trackConn(UserInputService.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end))
	trackConn(UserInputService.InputChanged:Connect(function(i)
		if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
			local rel = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
			local val = math.round(minVal + rel * (maxVal - minVal))
			local pct = (val - minVal) / (maxVal - minVal)
			fill.Size = UDim2.new(pct, 0, 1, 0)
			knob.Position = UDim2.new(pct, -5, 0, -3)
			lbl.Text = labelText..": "..tostring(val)
			onChange(val)
		end
	end))
end

