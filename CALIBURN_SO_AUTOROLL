-- Act stands (name contains "ACT 1") can't go through the normal evolution
-- pipeline, so we skip Evo handling and treat them as ordinary wanted matches.
local function isActStand(stand)
	if not stand or not stand.Name then return false end
	return stand.Name:find("ACT 1") ~= nil
end

local function getCurrentUtility()
	local character = LocalPlayer.Character
	if not character then return "None" end
	local status = character:FindFirstChild("Status")
	if not status then return "None" end
	local util = status:FindFirstChild("Utility")
	if not util then return "None" end
	return util.Value or "None"
end

local function isStandOut()
	local character = LocalPlayer.Character
	if not character then return false end
	local status = character:FindFirstChild("Status")
	if not status then return false end
	local standOut = status:FindFirstChild("StandOut")
	if not standOut then return false end
	return standOut.Value == true
end

-- Fires SummonStand until the StandOut flag flips true (or gives up).
local function summonStand()
	if isStandOut() then return true end

	local gui = LocalPlayer:FindFirstChild("PlayerGui")
	local core = gui and gui:FindFirstChild("CoreGUI")
	local events = core and core:FindFirstChild("Events")
	local summon = events and events:FindFirstChild("SummonStand")
	if not summon then return false end

	for _ = 1, 5 do
		pcall(function() summon:InvokeServer() end)
		for _ = 1, 10 do
			task.wait(0.2)
			if isStandOut() then return true end
		end
	end
	return isStandOut()
end

-- Same equip procedure as useStandArrow, generalised to any item + remote.
-- Returns true if the remote was invoked, false on a glitch/error.
local function equipAndFireItem(itemName, remote)
	local character = LocalPlayer.Character
	if not character or not character.Parent or not character:FindFirstChild("HumanoidRootPart") then
		character = LocalPlayer.CharacterAdded:Wait()
		character:WaitForChild("HumanoidRootPart")
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return false end

	-- Trade UI has to be closed before any tool can be equipped, same as
	-- rolling. Skip if it's already gone.
	local trade = PlayerGui:FindFirstChild("Trade")
	if trade then
		local events = trade:FindFirstChild("Events")
		local closeRemote = events and events:FindFirstChild("Close")
		if closeRemote then
			pcall(function() closeRemote:FireServer() end)
			task.wait(1)
		end
	end

	pcall(function() humanoid:UnequipTools() end)

	local function findItem(name)
		local backpack = LocalPlayer:FindFirstChild("Backpack")
		if backpack then
			local i = backpack:FindFirstChild(name)
			if i then return i end
		end
		if character then
			local i = character:FindFirstChild(name)
			if i then return i end
		end
		return nil
	end

	local item = findItem(itemName)
	if not item then
		-- Same glitch recovery as the stand arrow path: buy + respawn.
		if getInventoryCount(itemName) > 0 then
			buyItem(itemName)
			pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Dead) end)
		end
		return false
	end

	local ok = pcall(function()
		humanoid:EquipTool(item)
		task.wait(1)
		remote:InvokeServer()
	end)
	return ok
end

-- Inspects a Move3 criteria list and returns the utility required to obtain
-- any of those moves, or nil if none of them need a utility.
local function determineRequiredUtility(move3List)
	if not move3List then return nil end
	for _, move in ipairs(move3List) do
		if move == "Hamon Mastery" then
			return "Hamon", "Hamon Headband", HamonRemote
		elseif move == "Sun Immunity" then
			return "Vampire", "Vampire Mask", VampireRemote
		elseif move == "Infinite Rotation" then
			return "Spin", "Steel Ball", SpinRemote
		end
	end
	return nil
end

local function evolutionItemAndRemote(evolutionName)
	if evolutionName == "OH" then
		return "Heavenly Diary", HeavenlyDiaryRemote
	elseif evolutionName == "Requiem" then
		return "Requiem Arrow", RequiemArrowRemote
	elseif evolutionName == "Refined" then
		return "Refined Arrow", RefinedArrowRemote
	end
	return nil, nil
end

-- Evolves the current stand and checks the resulting Move3 against evoSpec.Move3.
-- Returns one of:
--   "match"    — Move3 matches; caller should stop AutoRoll.
--   "no_match" — Evolution finished but Move3 doesn't match; caller should reroll.
--   "stop"     — Fatal failure (out of money etc.); notifyWarn already called.
--   "retry"    — Transient failure (glitch); caller should wait briefly and try again.
local function performEvolution(matchName, evoSpec)
	local evoItem, evoRemote = evolutionItemAndRemote(evoSpec.Evolution)
	if not evoItem then
		notifyWarn(("[AutoRoll] Unknown Evolution \"%s\" for %s. Stopping."):format(tostring(evoSpec.Evolution), matchName))
		return "stop"
	end

	-- If Move3 includes a utility-locked move, obtain that utility first.
	local utilName, utilItem, utilRemote = determineRequiredUtility(evoSpec.Move3)
	if utilName and getCurrentUtility() == "None" then
		if not ensureItemInStock(utilItem) then
			notifyWarn(("[AutoRoll] Couldn't acquire %s — out of money? Stopping."):format(utilItem))
			return "stop"
		end
		if not equipAndFireItem(utilItem, utilRemote) then
			return "retry"
		end
		-- Wait for Utility to flip away from "None".
		local got = false
		for _ = 1, 20 do
			task.wait(0.25)
			if getCurrentUtility() ~= "None" then got = true; break end
		end
		if not got then return "retry" end
	end

	-- Stand must be summoned before evolving.
	if not summonStand() then return "retry" end

	if not ensureItemInStock(evoItem) then
		notifyWarn(("[AutoRoll] Couldn't acquire %s — out of money? Stopping."):format(evoItem))
		return "stop"
	end
	if not equipAndFireItem(evoItem, evoRemote) then
		return "retry"
	end
	notify(("[AutoRoll] Evolving \"%s\" to %s..."):format(matchName, evoSpec.Evolution))

	-- Wait for Move3 to populate. If it stays "None", refire the evolution.
	for attempt = 1, 5 do
		task.wait(2)
		local newStand = getCurrentStand()
		if newStand and newStand.Move3 and newStand.Move3 ~= "None" then
			if evoSpec.Move3 == nil or moveListContains(evoSpec.Move3, newStand.Move3) then
				notify(("[AutoRoll] Evolution success for \"%s\" — Move 3 \"%s\" matches. Stopping."):format(matchName, newStand.Move3))
				return "match"
			else
				notify(("[AutoRoll] Evolution failed for \"%s\" — Move 3 \"%s\" doesn't match, rerolling."):format(matchName, newStand.Move3))
				return "no_match"
			end
		end

		if attempt < 5 then
			if not ensureItemInStock(evoItem) then
				notifyWarn(("[AutoRoll] Couldn't acquire %s — out of money? Stopping."):format(evoItem))
				return "stop"
			end
			summonStand()
			if not equipAndFireItem(evoItem, evoRemote) then
				return "retry"
			end
		end
	end

	return "retry"
end

