_G.AutoRollCleanup = function()
	if _G.AutoRollSettings then
		_G.AutoRollSettings.AutoRoll = false
	end
	if _loopThread then
		pcall(task.cancel, _loopThread)
	end
	for _, c in pairs(_connections) do
		pcall(function() c:Disconnect() end)
	end
	table.clear(_connections)
	local existing = CoreGui:FindFirstChild("AutoRollGUI")
	if existing then existing:Destroy() end
end

----------------------------------------------------------------
-- MAIN LOOP
----------------------------------------------------------------

_loopThread = task.spawn(function()
	while task.wait(0.1) do
		local settings = _G.AutoRollSettings
		if not settings.AutoRoll then
			continue
		end

		-- 1. Read the current stand (waits until Trade GUI gives valid data).
		local stand = getCurrentStand()

		-- 2. Already on a wanted stand? Stop or evolve. (Unless moveset is blacklisted.)
		local matched, matchName = isWantedStand(stand)
		if matched and isMovesetBlacklisted(stand) then
			matched = false
		end
		if matched then
			local matchCriteria = settings.WantedStands[matchName]
			local evo = matchCriteria and matchCriteria.Evo
			if settings.AutoEvolve and evo then
				if isActStand(stand) then
					-- Act stands can't be evolved — stop as if it were a normal match.
					settings.AutoRoll = false
					if autoRollSetter then autoRollSetter(false) end
					notify(("[AutoRoll] Wanted stand found (\"%s\") but it's an Act stand and can't be evolved. Stopping."):format(matchName))
					continue
				end
				local result = performEvolution(matchName, evo)
				if result == "match" then
					settings.AutoRoll = false
					if autoRollSetter then autoRollSetter(false) end
					continue
				elseif result == "stop" then
					settings.AutoRoll = false
					if autoRollSetter then autoRollSetter(false) end
					continue
				elseif result == "retry" then
					task.wait(1)
					continue
				end
				-- "no_match": fall through to roll again.
			else
				settings.AutoRoll = false
				if autoRollSetter then autoRollSetter(false) end
				notify(("[AutoRoll] Wanted stand found (\"%s\"). Stopping."):format(matchName))
				continue
			end
		end

		-- 3. Make sure we have a Rokakaka and a Stand Arrow (buys if not).
		if not ensureItemInStock(settings.RollCostItemName) then
			notifyWarn(("[AutoRoll] Couldn't acquire %s — out of money? Stopping."):format(settings.RollCostItemName))
			settings.AutoRoll = false
			if autoRollSetter then autoRollSetter(false) end
			continue
		end
		if not ensureItemInStock(settings.StandArrow) then
			notifyWarn(("[AutoRoll] Couldn't acquire %s — out of money? Stopping."):format(settings.StandArrow))
			settings.AutoRoll = false
			if autoRollSetter then autoRollSetter(false) end
			continue
		end

		-- 4. Roll. If something errors, retry on the next tick.
		local ok = useStandArrow()
		if not ok then
			task.wait(1)
			continue
		end

		-- 5. Wait for the roll/respawn to complete before reading again.
		task.wait(settings.RollDelay)
	end
end)
