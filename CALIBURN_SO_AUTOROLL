----------------------------------------------------------------
-- NOTIFICATIONS (console + optional Discord webhook)
----------------------------------------------------------------

local function sendWebhook(message)
	local url = _G.WebhookURL
	if not url or url == "" then return end

	-- Pick whichever HTTP-request function the executor exposes.
	local requester = (syn and syn.request) or http_request or request
		or (http and http.request)
	if not requester then return end

	pcall(function()
		requester({
			Url = url,
			Method = "POST",
			Headers = { ["Content-Type"] = "application/json" },
			Body = HttpService:JSONEncode({
				embeds = {{
					author = { name = "Caliburn Auto Roll" },
					title = LocalPlayer.Name,
					description = message,
				}}
			}),
		})
	end)
end

local function notify(message)
	print(message)
	task.spawn(sendWebhook, message)
end

local function notifyWarn(message)
	warn(message)
	task.spawn(sendWebhook, message)
end

----------------------------------------------------------------
-- CRITERIA MATCHING
----------------------------------------------------------------

local function listContains(list, value)
	if not list then return false end
	for _, v in ipairs(list) do
		if v == value then return true end
	end
	return false
end

-- Move aliases — moves in the same group are treated as the same move when
-- checking criteria. Listing any one of them in a Wanted Stand's Move1/Move2
-- will also match any other move from its group on the rolled stand.
local MoveAliases = {
	{"Sword Combat", "Arrow Combat", "Pole Combat", "Paintbrush Combat", "Bayonet Combat", "Scythe Combat", "Bow Combat", "Pen Combat", "Cutlass Combat", "Trident Combat", "Shovel Combat", "Umbrella Combat", "Cane Combat"},
	{"Primary Bomb", "Internal Bomb", "Time Bomb"},
	{"Gun", "Revolver", "Flintlock", "Blunderbuss", "Wand", "Shotgun", "Water Gun", "Tommy Gun", "Bananagun"},
	{"Knife Throw", "Scale Throw", "Rose Throw", "Sharp Balloon"},
	{"Bubble Bomb", "Tri-Bubble Bomb"},
	{"Grenade", "Dynamite", "Skull Bomb", "Poison Potion", "Coin Toss", "Grenade Launcher"},
	{"Harpoon", "Spear Throw", "Sword Shot", "Balloon Sword", "Bow Shot", "Trident Throw"},
	{"Bearing Shot", "Baseball Throw", "Cannon Ball", "Balloon Shot", "Snowball Throw"},
	{"Star Finger", "Heel Extend"},
	{"Virus Capsule", "Superfast Jellyfish"},
	{"Sheer Heart Attack", "Rat Bomb", "Balloon Dog"},
	{"Over Heaven Blast", "Ocean Blast"}, 
	{"Reality Overwrite", "Stand Steal"},
	{"Life Beam", "Go Beyond"},
	{"Universal Barrage", "Universal Slice", "Universal Chop", "Universal Chomp", "Universal Icicle Barrage"},
	{"Void Ball", "Void Slash"},
}

-- Build a name -> group lookup so checks are O(1).
local MoveGroupOf = {}
for _, group in ipairs(MoveAliases) do
	for _, name in ipairs(group) do
		MoveGroupOf[name] = group
	end
end

-- True if two move names refer to the same underlying move (same alias group),
-- or are exactly equal.
local function movesEquivalent(a, b)
	if a == b then return true end
	local groupA = MoveGroupOf[a]
	return groupA ~= nil and groupA == MoveGroupOf[b]
end

-- Like listContains, but treats aliased move names as equivalent.
local function moveListContains(list, move)
	if not list then return false end
	for _, candidate in ipairs(list) do
		if movesEquivalent(candidate, move) then return true end
	end
	return false
end

local function standMatchesCriteria(stand, criteria)
	if criteria.Suit ~= nil then
		if stand.Suit ~= criteria.Suit then
			return false
		end
	end

	if criteria.Size ~= nil then
		if stand.Size == nil or stand.Size < criteria.Size then
			return false
		end
	end

	if criteria.Body ~= nil and stand.Body ~= criteria.Body then
		return false
	end

	if criteria.Head ~= nil and stand.Head ~= criteria.Head then
		return false
	end

	local moves = criteria.Moves
	if moves then
		if moves.Move1 ~= nil and not moveListContains(moves.Move1, stand.Move1) then
			return false
		end
		if moves.Move2 ~= nil and not moveListContains(moves.Move2, stand.Move2) then
			return false
		end
	end

	return true
end

-- Returns (true, name) for the first matching named entry, or (false, nil).
local function isWantedStand(stand)
	if not stand then return false, nil end
	for name, criteria in pairs(_G.AutoRollSettings.WantedStands) do
		if standMatchesCriteria(stand, criteria) then
			return true, name
		end
	end
	return false, nil
end

-- True if the stand's moveset matches any entry in the moveset blacklist.
-- Each entry uses the same Move1/Move2 semantics as WantedStands.Moves:
-- both move lists are AND'd, lists are OR within themselves, nil = ignore,
-- and the alias system applies.
local function isMovesetBlacklisted(stand)
	if not stand then return false end
	local blacklist = _G.AutoRollSettings.MovesetBlacklist
	if not blacklist then return false end
	for _, entry in ipairs(blacklist) do
		local m1Match = entry.Move1 == nil or moveListContains(entry.Move1, stand.Move1)
		local m2Match = entry.Move2 == nil or moveListContains(entry.Move2, stand.Move2)
		if m1Match and m2Match then
			-- Don't fire on an empty entry ({} or {Move1=nil, Move2=nil}) —
			-- that would blacklist literally every stand.
			if entry.Move1 ~= nil or entry.Move2 ~= nil then
				return true
			end
		end
	end
	return false
end

----------------------------------------------------------------
-- STAND INFO (read from Trade GUI)
----------------------------------------------------------------

local function parseAfterColon(text)
	if not text then return nil end
	return text:match("^[^:]+:%s*(.+)$")
end

local function parseScale(text)
	if not text then return nil end
	return tonumber(text:match("x([%d%.]+)"))
end

local function readStandFromTradeGui(trade)
	local frame = trade:FindFirstChild("Frame")
	local stats = frame and frame:FindFirstChild("Stats")
	if not stats then return nil end

	-- A stand is "Suit" if there's a StandSuit model under the character.
	-- Missing character is treated as not-a-suit.
	local function isSuit()
		local character = LocalPlayer.Character
		return character ~= nil and character:FindFirstChild("StandSuit") ~= nil
	end

	-- If the Stats panel is hidden, the player currently has no stand.
	-- Return a sentinel "no stand" reading so the caller proceeds to roll
	-- instead of looping forever waiting for a stand that isn't there.
	if stats.Visible == false then
		return {
			Name  = "None",
			Size  = 0,
			Body  = "None",
			Head  = "None",
			Move1 = "None",
			Move2 = "None",
			Move3 = "None",
			Suit  = false,
		}
	end

	local nameLabel  = stats:FindFirstChild("StandName")
	local bodyLabel  = stats:FindFirstChild("StandBody")
	local headLabel  = stats:FindFirstChild("StandHead")
	local scaleLabel = stats:FindFirstChild("StandScale")
	local movesFrame = stats:FindFirstChild("Moves")
	if not (bodyLabel and headLabel and scaleLabel and movesFrame) then
		return nil
	end

	local m1Frame = movesFrame:FindFirstChild("4")
	local m2Frame = movesFrame:FindFirstChild("5")
	local m3Frame = movesFrame:FindFirstChild("6")
	local m1Text  = m1Frame and m1Frame:FindFirstChild("Text2")
	local m2Text  = m2Frame and m2Frame:FindFirstChild("Text2")
	local m3Text  = m3Frame and m3Frame:FindFirstChild("Text2")
	if not (m1Text and m2Text) then return nil end

	local name  = (nameLabel and nameLabel.Text ~= "" and nameLabel.Text) or "None"
	local size  = parseScale(scaleLabel.Text)
	local body  = parseAfterColon(bodyLabel.Text)
	local head  = parseAfterColon(headLabel.Text)
	local move1 = m1Text.Text
	local move2 = m2Text.Text
	local move3 = (m3Text and m3Text.Text ~= "" and m3Text.Text) or "None"

	if not size or not body or not head
		or move1 == nil or move1 == ""
		or move2 == nil or move2 == ""
	then
		return nil
	end

	return {
		Name  = name,
		Size  = size,
		Body  = body,
		Head  = head,
		Move1 = move1,
		Move2 = move2,
		Move3 = move3,
		Suit  = isSuit(),
	}
end

local function getCurrentStand()
	while true do
		local trade = PlayerGui:FindFirstChild("Trade")

		if not trade then
			pcall(function()
				ViewStandRemote:InvokeServer(LocalPlayer)
			end)
			task.wait(0.25)
		else
			local stand = readStandFromTradeGui(trade)
			if stand then
				if updateLastStandDisplay then
					pcall(updateLastStandDisplay, stand)
				end
				return stand
			end
			task.wait(0.1)
		end
	end
end

